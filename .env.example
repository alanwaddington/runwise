# Site URL for canonical links, sitemap, and OG tags.
# Set in Vercel production env. Defaults to https://runwise.app if unset.
# VITE_SITE_URL=https://runwise.app

# Google Search Console site-ownership verification token (optional).
# Meta-tag verification: https://search.google.com/search-console -> Add property -> HTML tag.
# Only the content="..." value is needed here, not the full <meta> tag.
PUBLIC_GOOGLE_SITE_VERIFICATION=
