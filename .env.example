# Site URL for canonical links, sitemap, and OG tags.
# Set in Vercel production env. Defaults to https://runwise.app if unset.
# VITE_SITE_URL=https://runwise.app

# Google Search Console site-ownership verification token (optional).
# Meta-tag verification: https://search.google.com/search-console -> Add property -> HTML tag.
# Only the content="..." value is needed here, not the full <meta> tag.
PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google AdSense account verification (optional — required to activate AdSense).
# Value: your AdSense Publisher ID (ca-pub-XXXXXXXXX).
# Get from: https://adsense.google.com -> Sites -> meta tag content value.
PUBLIC_GOOGLE_ADSENSE_ACCOUNT=ca-pub-3134773761004102

# Google AdSense publisher ID (optional — ads only serve when this is set and user consents).
# Format: ca-pub-XXXXXXXXXXXXXXXXX
# Find yours at: https://adsense.google.com -> Account -> Account information
PUBLIC_ADSENSE_CLIENT_ID=
