		"og:generate": "node scripts/generate-og-images.js"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-vercel": "^6.3.4",
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.4.2",
		"@types/node": "^26.0.1",
		"@vitest/ui": "^4.1.9",
		"eslint": "^9.0.0",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"jsdom": "^29.1.1",
		"marked": "^18.0.5",
		"pdfkit": "^0.19.1",
		"prettier": "^3.9.4",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.1",
		"vite": "^8.1.1",
		"vitest": "^4.1.9"
	},
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"dependencies": {
		"@vercel/analytics": "^2.0.1"
